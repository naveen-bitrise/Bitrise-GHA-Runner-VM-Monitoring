{
  "name": "GHA Runner VM Monitoring Test 17",
  "description": null,
  "permissions": "PUBLIC_READ_WRITE",
  "pages": [
    {
      "name": "VM Metrics",
      "description": null,
      "widgets": [
        {
          "title": "CPU Usage Over Time",
          "layout": { "column": 1, "row": 1, "width": 12, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [7914226],
                "query": "SELECT average(gha.vm.cpu.user_pct) AS 'user %' FROM Metric WHERE runner.os = {{machine_type}} TIMESERIES AUTO"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        }
      ]
    }
  ],
  "variables": [
    {
      "name": "machine_type",
      "title": "Machine Type",
      "type": "NRQL",
      "isMultiSelection": false,
      "replacementStrategy": "STRING",
      "defaultValues": [],
      "nrqlQuery": {
        "accountIds": [7914226],
        "query": "SELECT uniques(runner.os) FROM Metric SINCE 1 week ago"
      }
    }
  ]
}
